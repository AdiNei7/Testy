type Opinia = { autor: string; tresc: string; ocena: number };

class Produkt {
    constructor(
        public nazwa: string,
        public cena: number,
        public opis: string,
        public opinie: Opinia[] = []
    ) {}
}

const Magazyn = new Map<Produkt, number>();

class KoszykItem {
    constructor(public produkt: Produkt, public ilosc: number) {
        if (ilosc <= 0) throw new Error("Ilość musi być większa niż 0");
    }
    get lacznaSuma() { return this.produkt.cena * this.ilosc; }
}

class Koszyk {
    produkty: KoszykItem[] = [];

    dodaj(ki: KoszykItem) {
        const wMagazynie = Magazyn.get(ki.produkt) ?? 0;
        const wKoszyku = this.produkty.find(p => p.produkt === ki.produkt);
        const nowaIlosc = (wKoszyku?.ilosc ?? 0) + ki.ilosc;

        if (wMagazynie < nowaIlosc) {
            return console.error(`Błąd: Brak wystarczającej ilości ${ki.produkt.nazwa} w magazynie!`);
        }

        wKoszyku ? (wKoszyku.ilosc += ki.ilosc) : this.produkty.push(ki);
        console.log(`Dodano ${ki.ilosc}x ${ki.produkt.nazwa} do koszyka.`);
    }

    get sumaCalkowita() {
        return this.produkty.reduce((acc, item) => acc + item.lacznaSuma, 0);
    }
}

class Uzytkownik {
    constructor(public readonly id: string) {}
}
