#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>

#define BUFFER_SIZE 1024

void handle_error(const char *msg) {
    perror(msg);
    exit(EXIT_FAILURE);
}

float get_system_uptime() {
    FILE *fp = fopen("/proc/uptime", "r");
    if (fp == NULL) return 0.0f;
    float uptime;
    fscanf(fp, "%f", &uptime);
    fclose(fp);
    return uptime;
}

int main(int argc, char *argv[]) {
    if (getuid() == 0) {
        fprintf(stderr, "Błąd: Uruchamianie z konta root jest zabronione.\n");
        exit(EXIT_FAILURE);
    }

    int port = (argc > 1) ? atoi(argv[1]) : 80;
    int server_fd, client_fd;
    struct sockaddr_in addr;
    int opt = 1;

    if ((server_fd = socket(AF_INET, SOCK_STREAM, 0)) < 0)
        handle_error("socket failed");

    if (setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt)) < 0)
        handle_error("setsockopt failed");

    memset(&addr, 0, sizeof(addr));
    addr.sin_family = AF_INET;
    addr.sin_addr.s_addr = htonl(INADDR_ANY);
    addr.sin_port = htons(port);

    if (bind(server_fd, (struct sockaddr *)&addr, sizeof(addr)) < 0)
        handle_error("bind failed");

    if (listen(server_fd, 5) < 0)
        handle_error("listen failed");

    printf("Serwer uruchomiony na porcie %d. Oczekiwanie na połączenia...\n", port);

    while (1) {
        struct sockaddr_in client_addr;
        socklen_t client_len = sizeof(client_addr);

        if ((client_fd = accept(server_fd, (struct sockaddr *)&client_addr, &client_len)) < 0) {
            perror("accept failed");
            continue;
        }

        printf("Połączenie z: %s:%d\n", inet_ntoa(client_addr.sin_addr), ntohs(client_addr.sin_port));

        char buffer[BUFFER_SIZE];
        ssize_t received = recv(client_fd, buffer, BUFFER_SIZE - 1, 0);
        if (received > 0) {
            buffer[received] = '\0';
            
            float uptime = get_system_uptime();
            char body[64];
            int body_len = snprintf(body, sizeof(body), "System uptime: %.2f seconds\n", uptime);

            const char* http_header = "HTTP/1.0 200 OK\r\n"
                                      "Content-Type: text/plain; charset=UTF-8\r\n"
                                      "Connection: close\r\n";
            char content_length[64];
            int cl_len = snprintf(content_length, sizeof(content_length), "Content-Length: %d\r\n\r\n", body_len);

            send(client_fd, http_header, strlen(http_header), 0);
            send(client_fd, content_length, cl_len, 0);
            send(client_fd, body, body_len, 0);
        }

        shutdown(client_fd, SHUT_WR);
        close(client_fd);
        printf("Połączenie zamknięte.\n");
    }

    close(server_fd);
    return 0;
}
